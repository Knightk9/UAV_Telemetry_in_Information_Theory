// Khởi tạo các chân GPIO thủ công (không phụ thuộc CubeMX)
void Setup_Custom_Pins(void) {
    GPIO_InitTypeDef GPIO_InitStruct = {0};

    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_GPIOB_CLK_ENABLE();

    // 1. Chân NRF Output (CE, CSN)
    GPIO_InitStruct.Pin = NRF_CE_PIN | NRF_CSN_PIN;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
    HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

    HAL_GPIO_WritePin(NRF_CE_PORT, NRF_CE_PIN, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(NRF_CSN_PORT, NRF_CSN_PIN, GPIO_PIN_SET);

    // 2. Chân NRF Input (IRQ - Tùy chọn)
    GPIO_InitStruct.Pin = NRF_IRQ_PIN;
    GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
    GPIO_InitStruct.Pull = GPIO_PULLUP;
    HAL_GPIO_Init(NRF_IRQ_PORT, &GPIO_InitStruct);

    // 3. Chân LED 7 đoạn trên PORT A (c: A9, d: A8, g: A10)
    GPIO_InitStruct.Pin = GPIO_PIN_8 | GPIO_PIN_9 | GPIO_PIN_10;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

    // 4. Chân LED 7 đoạn trên PORT B
    // Digits: 1(B8), 2(B7), 3(B6), 4(B5)
    // Segments: a(B12), b(B13), f(B14), e(B15)
    GPIO_InitStruct.Pin = GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7 | GPIO_PIN_8 |
                          GPIO_PIN_12 | GPIO_PIN_13 | GPIO_PIN_14 | GPIO_PIN_15;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);
}

// Bóc tách từng bit mã Hex để điều khiển các chân rải rác
void set_segment(uint8_t val) {
    // val & 0x01 = bit 0 (a), val & 0x02 = bit 1 (b), v.v...
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, (val & 0x01) ? GPIO_PIN_SET : GPIO_PIN_RESET); // a - B12
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, (val & 0x02) ? GPIO_PIN_SET : GPIO_PIN_RESET); // b - B13
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_9,  (val & 0x04) ? GPIO_PIN_SET : GPIO_PIN_RESET); // c - A9
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_8,  (val & 0x08) ? GPIO_PIN_SET : GPIO_PIN_RESET); // d - A8
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_15, (val & 0x10) ? GPIO_PIN_SET : GPIO_PIN_RESET); // e - B15
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_14, (val & 0x20) ? GPIO_PIN_SET : GPIO_PIN_RESET); // f - B14
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_10, (val & 0x40) ? GPIO_PIN_SET : GPIO_PIN_RESET); // g - A10
}

void display_7seg(uint8_t temp) {
    uint8_t digits[4] = {0, 0, temp / 10, temp % 10}; // Mảng hiển thị (Ví dụ: 0, 0, 2, 7)
    uint16_t dig_pins[4] = {GPIO_PIN_8, GPIO_PIN_7, GPIO_PIN_6, GPIO_PIN_5}; // Thứ tự chân quét LED 1 -> 4

    for (int i = 0; i < 4; i++) {
        // Tắt tất cả các digit để chống lem chữ (Kéo Anode xuống LOW)
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_8 | GPIO_PIN_7 | GPIO_PIN_6 | GPIO_PIN_5, GPIO_PIN_RESET);

        // Nạp dữ liệu vào các chân a-g
        set_segment(segment_map[digits[i]]);

        // Bật digit hiện tại (Kéo Anode lên HIGH)
        HAL_GPIO_WritePin(GPIOB, dig_pins[i], GPIO_PIN_SET);

        // Trễ để lưu ảnh trên võng mạc
        delay_us(3000);
    }
}

uint8_t hamming_74_encode(uint8_t data_nibble) {
    uint8_t d1 = (data_nibble >> 3) & 0x01;
    uint8_t d2 = (data_nibble >> 2) & 0x01;
    uint8_t d3 = (data_nibble >> 1) & 0x01;
    uint8_t d4 = data_nibble & 0x01;

    uint8_t p1 = d1 ^ d2 ^ d4;
    uint8_t p2 = d1 ^ d3 ^ d4;
    uint8_t p3 = d2 ^ d3 ^ d4;

    return (p1 << 7) | (p2 << 6) | (d1 << 5) | (p3 << 4) | (d2 << 3) | (d3 << 2) | (d4 << 1);
}

void nrf_csn(uint8_t state) {
    HAL_GPIO_WritePin(NRF_CSN_PORT, NRF_CSN_PIN, state ? GPIO_PIN_SET : GPIO_PIN_RESET);
}

void nrf_ce(uint8_t state) {
    HAL_GPIO_WritePin(NRF_CE_PORT, NRF_CE_PIN, state ? GPIO_PIN_SET : GPIO_PIN_RESET);
}

uint8_t spi_transfer(uint8_t data) {
    uint8_t rx_data;
    HAL_SPI_TransmitReceive(&hspi1, &data, &rx_data, 1, HAL_MAX_DELAY);
    return rx_data;
}

void nrf_write_reg(uint8_t reg, uint8_t value) {
    nrf_csn(0);
    spi_transfer(W_REGISTER | (reg & 0x1F));
    spi_transfer(value);
    nrf_csn(1);
}

void nrf_init_tx(void) {
    nrf_ce(0);
    nrf_write_reg(NRF_EN_AA, 0x00);
    nrf_write_reg(NRF_SETUP_RETR, 0x00);
    nrf_write_reg(NRF_RF_CH, 76);
    nrf_write_reg(NRF_RF_SETUP, 0x06);
    nrf_write_reg(NRF_CONFIG, 0x02);
    HAL_Delay(2);
}

void nrf_transmit(uint8_t *data) {
    nrf_csn(0);
    spi_transfer(FLUSH_TX);
    nrf_csn(1);

    nrf_csn(0);
    spi_transfer(W_TX_PAYLOAD);
    for (int i = 0; i < 32; i++) {
        spi_transfer(data[i]);
    }
    nrf_csn(1);

    nrf_ce(1);
    for(volatile int i=0; i<500; i++); // Ngâm chân CE để bắn sóng
    nrf_ce(0);

    nrf_write_reg(NRF_STATUS, (1 << 5)); // Xóa cờ TX_DS
}

void DWT_Init(void) {
    CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
    DWT->CYCCNT = 0;
    DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
}

void delay_us(uint32_t us) {
    uint32_t startTick = DWT->CYCCNT, targetTick = us * (SystemCoreClock / 1000000);
    while (DWT->CYCCNT - startTick < targetTick);
}

void DHT11_Start(void) {
    GPIO_InitTypeDef GPIO_InitStruct = {0};
    GPIO_InitStruct.Pin = DHT11_PIN;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
    HAL_GPIO_Init(DHT11_PORT, &GPIO_InitStruct);

    HAL_GPIO_WritePin(DHT11_PORT, DHT11_PIN, GPIO_PIN_RESET);
    HAL_Delay(18);
    HAL_GPIO_WritePin(DHT11_PORT, DHT11_PIN, GPIO_PIN_SET);
    delay_us(20);

    GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
    HAL_GPIO_Init(DHT11_PORT, &GPIO_InitStruct);
}

uint8_t DHT11_Read(void) {
    uint8_t data = 0;
    for (int j = 0; j < 8; j++) {
        while (!(HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN)));
        delay_us(40);
        if (!(HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN))) {
            data &= ~(1 << (7 - j));
        } else {
            data |= (1 << (7 - j));
            while (HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN));
        }
    }
    return data;
}

void get_temperature(void) {
    uint8_t rh_byte1, rh_byte2, temp_byte1, temp_byte2, checksum;
    DHT11_Start();

    // Bắt đầu chuỗi phản hồi từ DHT11
    while (HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN));
    while (!(HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN)));
    while (HAL_GPIO_ReadPin(DHT11_PORT, DHT11_PIN));

    rh_byte1 = DHT11_Read();
    rh_byte2 = DHT11_Read();
    temp_byte1 = DHT11_Read();
    temp_byte2 = DHT11_Read();
    checksum = DHT11_Read();

    if (rh_byte1 + rh_byte2 + temp_byte1 + temp_byte2 == checksum) {
        temp_c = temp_byte1;
    }
}
