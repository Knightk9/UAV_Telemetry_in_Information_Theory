  /* USER CODE BEGIN 2 */
  Setup_Custom_Pins(); // Gọi hàm thiết lập chân vật lý ở đây
  DWT_Init();
  nrf_init_tx();
  last_tx_time = HAL_GetTick();
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
    display_7seg(temp_c); // Hàm này chứa delay_us(3000) * 4 = 12ms

    // Bắn dữ liệu lên không trung mỗi 1 giây
    if (HAL_GetTick() - last_tx_time > 1000) {
        get_temperature();
        memset(payload, 0, 32);

        payload[0] = seq_num++;

        uint8_t high_nibble = (temp_c >> 4) & 0x0F;
        uint8_t low_nibble = temp_c & 0x0F;

        payload[1] = hamming_74_encode(high_nibble);
        payload[2] = hamming_74_encode(low_nibble);

        nrf_transmit(payload);

        last_tx_time = HAL_GetTick();
    }
  }
  /* USER CODE END 3 */
}

