void NRF24L01_PingPong_Handler(void) {
    // 1. Chuyển sang RX Mode để lắng nghe PING
    uint8_t cfg = NRF24_ReadReg(0x00);
    NRF24_WriteReg(0x00, cfg | 0x01);
    NRF24_WriteReg(0x07, 0x70); // Xóa sạch cờ rác
    HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_SET);

    // NRF cần 130us để ổn định RX. Việc delay 1ms ở đây giúp nó sẵn sàng 100%.
    // Trong khi đó, ESP32 bên kia sẽ bị ép đợi 2ms mới được bắn PING.
    HAL_Delay(1);

    uint32_t timeout_start = HAL_GetTick();
    uint8_t got_ping = 0;
    uint8_t rx_buf[32];

    // Chờ PING (Timeout 100ms)
    while (HAL_GetTick() - timeout_start < 100) {
        if (NRF24_ReadReg(0x07) & 0x40) {
            NRF24_ReadPayload(rx_buf, 32);
            NRF24_WriteReg(0x07, 0x40); // Xóa cờ RX_DR
            if (strncmp((char*)rx_buf, "PING", 4) == 0) {
                got_ping = 1;
                break;
            }
        }
    }

    // 2. Nếu có PING, chuyển về TX để phát PONG
    if (got_ping) {
        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);
        cfg = NRF24_ReadReg(0x00);
        NRF24_WriteReg(0x00, cfg & ~0x01);
        NRF24_WriteReg(0x07, 0x70);

        uint8_t tx_payload[32] = {0};
        strcpy((char*)tx_payload, "PONG");
        NRF24_WritePayload(tx_payload, 32);

        // BẮT BUỘC THÊM: Đợi 2ms để ESP32 chuyển từ TX sang RX xong xuôi
        HAL_Delay(2);

        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_SET);
        HAL_Delay(1); // Xung CE để bắn
        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);

        uint32_t pong_timeout = HAL_GetTick();
        while ((NRF24_ReadReg(0x07) & 0x20) == 0) { // Đợi báo phát thành công
            if (HAL_GetTick() - pong_timeout > 5) break;
        }
        NRF24_WriteReg(0x07, 0x20); // Xóa cờ
    }

    HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);
}

