// =====================================================================
// ĐỌC VÀ LƯỢNG TỬ HÓA CẢM BIẾN MPU6050
// =====================================================================
void MPU6050_Read_DMP(int32_t *p, int32_t *y, int32_t *r) {
    short gyro[3], accel[3], sensors;
    long quat[4];
    unsigned char more;
    unsigned long timestamp;
    float q0, q1, q2, q3;
    float pitch, yaw, roll;

    if (dmp_read_fifo(gyro, accel, quat, &timestamp, &sensors, &more) == 0) {
        if (sensors & INV_WXYZ_QUAT) {
            q0 = quat[0] / 1073741824.0f;
            q1 = quat[1] / 1073741824.0f;
            q2 = quat[2] / 1073741824.0f;
            q3 = quat[3] / 1073741824.0f;

            pitch = asin(2.0f * (q0*q2 - q3*q1));
            yaw   = atan2(2.0f * (q0*q3 + q1*q2), q0*q0 + q1*q1 - q2*q2 - q3*q3);
            roll  = atan2(2.0f * (q0*q1 + q2*q3), q0*q0 - q1*q1 - q2*q2 + q3*q3);

            *p = (int32_t)(pitch * (180.0f / M_PI) * 100.0f);
            *y = (int32_t)(yaw * (180.0f / M_PI) * 100.0f);
            *r = (int32_t)(roll * (180.0f / M_PI) * 100.0f);
        }
    }
}

