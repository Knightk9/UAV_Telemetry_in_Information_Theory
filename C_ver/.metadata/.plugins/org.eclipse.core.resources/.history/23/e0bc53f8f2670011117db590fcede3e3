// Cập nhật lại hàm Khởi tạo, ÉP CỨNG cấu hình RF
void NRF24_Init(void) {
    HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET); // Tạm dừng thu/phát để config

    NRF24_WriteReg(0x00, 0x02); // Tắt CRC
    NRF24_WriteReg(0x01, 0x00); // EN_AA: Tắt hoàn toàn Auto ACK
    NRF24_WriteReg(0x02, 0x01); // EN_RXADDR: Chỉ bật luồng dữ liệu Pipe 0
    NRF24_WriteReg(0x03, 0x03); // SETUP_AW: Độ dài địa chỉ là 5 Bytes
    NRF24_WriteReg(0x05, 76);   // RF_CH: Ép chạy ở Kênh 76 (2476 MHz) - Tránh WiFi
    NRF24_WriteReg(0x06, 0x0F); // RF_SETUP: Tốc độ 2Mbps, Công suất phát mạnh nhất 0dBm
    NRF24_WriteReg(0x11, 32);   // RX_PW_P0: Ép cứng khung truyền đúng 32 bytes

    // ĐỒNG BỘ ĐỊA CHỈ: Gán chung 1 mã định danh "1122334455" cho cả TX và RX
    uint8_t sync_addr[5] = {0x11, 0x22, 0x33, 0x44, 0x55};
    NRF24_WriteRegisterMulti(0x10, sync_addr, 5); // TX_ADDR (Địa chỉ đích để bắn tới)
    NRF24_WriteRegisterMulti(0x0A, sync_addr, 5); // RX_ADDR_P0 (Địa chỉ nhà để mở cửa nhận)

    HAL_Delay(2); // Chờ dao động thạch anh trên NRF ổn định
}

// =====================================================================
// TRUYỀN DỮ LIỆU & GIAO THỨC PING-PONG
// =====================================================================
void NRF24L01_Transmit(uint8_t *data, uint32_t size) {
    uint32_t bytes_sent = 0;
    uint8_t tx_payload[32];

    // Ép sang TX Mode
    uint8_t cfg = NRF24_ReadReg(0x00);
    NRF24_WriteReg(0x00, cfg & ~0x01);
    HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);

    while (bytes_sent < size) {
        uint8_t chunk_size = (size - bytes_sent >= 32) ? 32 : (size - bytes_sent);
        memset(tx_payload, 0, 32);
        memcpy(tx_payload, &data[bytes_sent], chunk_size);

        // Xóa tất cả các cờ ngắt để NRF không bị kẹt ở trạng thái lỗi
        NRF24_WriteReg(0x07, 0x30);

        NRF24_WritePayload(tx_payload, 32);

        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_SET);
        HAL_Delay(1);
        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);

        // THÊM TIMEOUT CHỐNG TREO STM32
        uint32_t tx_timeout = HAL_GetTick();
        // Kiểm tra cả cờ TX_DS (0x20) và cờ lỗi MAX_RT (0x10)
        while ((NRF24_ReadReg(0x07) & 0x30) == 0) {
            if (HAL_GetTick() - tx_timeout > 5) break; // Hủy chờ sau 5ms
        }


        bytes_sent += chunk_size;
    }
}

