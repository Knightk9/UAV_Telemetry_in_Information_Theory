/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/
  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_I2C1_Init();

  /* USER CODE BEGIN 2 */
  LCD_Init();
  NRF24_Init();

  uint8_t test_spi = NRF24_ReadReg(0x00);
    char test_msg[17];
    snprintf(test_msg, sizeof(test_msg), "SPI REG: 0x%02X  ", test_spi);

    LCD_SendCommand(0x01);
    LCD_DisplayString(0, 0, test_msg);
    HAL_Delay(3000);

  // Khởi tạo thư viện fMeow MPU6050
  LCD_DisplayString(0, 0, "MPU Init...");
  while (mpu_init(NULL) != 0) {
      LCD_DisplayString(0, 0, "MPU Init Fail! ");
      HAL_Delay(500);
  }
  mpu_set_sensors(INV_XYZ_GYRO | INV_XYZ_ACCEL);
  mpu_configure_fifo(INV_XYZ_GYRO | INV_XYZ_ACCEL);
  dmp_load_motion_driver_firmware();
  dmp_enable_feature(DMP_FEATURE_6X_LP_QUAT | DMP_FEATURE_SEND_RAW_ACCEL | DMP_FEATURE_SEND_CAL_GYRO | DMP_FEATURE_GYRO_CAL);
  dmp_set_fifo_rate(100);
  mpu_set_dmp_state(1);

  LCD_DisplayString(0, 0, "MPU DMP OK!   ");
  HAL_Delay(1000);

  char lcd_line1[17];
  char lcd_line2[17];

  int32_t raw_pitch = 0, raw_yaw = 0, raw_roll = 0;
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    MPU6050_Read_DMP(&raw_pitch, &raw_yaw, &raw_roll);

    // Quantization
    current_measurements[0] = raw_pitch;
    current_measurements[1] = raw_yaw;
    current_measurements[2] = raw_roll;

    // Cập nhật LCD
    int16_t disp_p = (int16_t)(current_measurements[0] / 10);
    int16_t disp_y = (int16_t)(current_measurements[1] / 10);
    int16_t disp_r = (int16_t)(current_measurements[2] / 10);

    if (matrix_column_idx == 0) {
        timestamp_sample_first = HAL_GetTick();

        data_matrix[0][0] = current_measurements[0];
        data_matrix[1][0] = current_measurements[1];
        data_matrix[2][0] = current_measurements[2];

        previous_measurements[0] = current_measurements[0];
        previous_measurements[1] = current_measurements[1];
        previous_measurements[2] = current_measurements[2];
        matrix_column_idx = 1;
    }
    else {
        data_matrix[0][matrix_column_idx] = current_measurements[0] - previous_measurements[0];
        data_matrix[1][matrix_column_idx] = current_measurements[1] - previous_measurements[1];
        data_matrix[2][matrix_column_idx] = current_measurements[2] - previous_measurements[2];

        previous_measurements[0] = current_measurements[0];
        previous_measurements[1] = current_measurements[1];
        previous_measurements[2] = current_measurements[2];
        matrix_column_idx++;

        if (matrix_column_idx >= 101) {
        	// Update telemetry on LCD display
        	snprintf(lcd_line1, sizeof(lcd_line1), "%+04d %+05d %+05d", disp_p, disp_y, disp_r);
        	LCD_DisplayString(0, 0, lcd_line1);

            timestamp_sample_last = HAL_GetTick();

            tx_packet.frame_id = frame_counter++;
            tx_packet.delayMin = HAL_GetTick() - timestamp_sample_last;

            Process_Source_Coding(data_matrix, &tx_packet);

            tx_packet.delayMax = HAL_GetTick() - timestamp_sample_first;

            snprintf(lcd_line2, sizeof(lcd_line2), "E %02.3f C %02.2f", tx_packet.source_entropy, tx_packet.compression_ratio);
            LCD_DisplayString(1, 0, lcd_line2);

            memset(channel_encoded_buffer, 0, sizeof(channel_encoded_buffer));
            uint32_t encoded_bytes_len = Process_Channel_Coding((uint8_t*)&tx_packet, sizeof(DataPacket_t), channel_encoded_buffer);

            // 1. Phát gói dữ liệu lớn
            NRF24L01_Transmit(channel_encoded_buffer, encoded_bytes_len);

            // 2. Chuyển trạng thái để Ping-Pong đo trễ đường truyền
            NRF24L01_PingPong_Handler();

            matrix_column_idx = 0;

            mpu_reset_fifo();
        }
    }
    HAL_Delay(10);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

