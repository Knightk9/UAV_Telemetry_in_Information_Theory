#include "convolutional.h"

uint32_t Process_Channel_Coding(uint8_t *input_bytes, uint32_t input_len_bytes, uint8_t *output_buffer) {
    uint32_t total_bits = input_len_bytes * 8;
    uint32_t out_bit_ptr = 0;

    // Cửa sổ trượt lưu trữ 3 trạng thái phần tử nhớ
    // Thanh ghi dịch bit hoạt động: [b0, b1, b2] trong đó b0 là bit mới nạp vào
    uint8_t shift_reg = 0;

    // Nạp bit flushing ban đầu gồm 2 bit '0'
    // Trên thực tế máy phát dịch chuyển liên tục từ trạng thái reset rỗng

    for (uint32_t i = 0; i < total_bits + 2; i++) {
        uint8_t current_bit = 0;
        if (i < total_bits) {
            uint32_t byte_idx = i / 8;
            uint8_t bit_idx = 7 - (i % 8);
            current_bit = (input_bytes[byte_idx] >> bit_idx) & 0x01;
        } else {
            current_bit = 0; // Đuôi 2 bit flushing '00' để ép FSM hồi quy về gốc 0
        }

        // Dịch chuyển bit vào thanh ghi ràng buộc K=3
        shift_reg = ((shift_reg << 1) | current_bit) & 0x07;

        uint8_t b0 = (shift_reg >> 2) & 0x01;
        uint8_t b1 = (shift_reg >> 1) & 0x01;
        uint8_t b2 = shift_reg & 0x01;

        // Thực hiện phép nhân Modulo 2 tương đương phép toán XOR của đa thức sinh
        // p1 = "111" => b0 XOR b1 XOR b2
        uint8_t out1 = b0 ^ b1 ^ b2;
        // p2 = "101" => b0 XOR b2
        uint8_t out2 = b0 ^ b2;
        // p3 = "110" => b0 XOR b1
        uint8_t out3 = b0 ^ b1;

        uint8_t outputs[3] = {out1, out2, out3};

        for (int j = 0; j < 3; j++) {
            uint32_t out_byte_pos = out_bit_ptr / 8;
            uint8_t out_bit_pos = 7 - (out_bit_ptr % 8);

            if (outputs[j]) {
                output_buffer[out_byte_pos] |= (1 << out_bit_pos);
            } else {
                output_buffer[out_byte_pos] &= ~(1 << out_bit_pos);
            }
            out_bit_ptr++;
        }
    }

    // Trả về kích thước độ dài dòng bit sau mã hóa tích chập theo đơn vị Byte
    return (out_bit_ptr + 7) / 8;
}
