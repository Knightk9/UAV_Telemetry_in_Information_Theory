void LCD_Write4Bit(uint8_t val) {
    HAL_GPIO_WritePin(LCD_D4_GPIO_PORT, LCD_D4_PIN, (val >> 0) & 0x01);
    HAL_GPIO_WritePin(LCD_D5_GPIO_PORT, LCD_D5_PIN, (val >> 1) & 0x01);
    HAL_GPIO_WritePin(LCD_D6_GPIO_PORT, LCD_D6_PIN, (val >> 2) & 0x01);
    HAL_GPIO_WritePin(LCD_D7_GPIO_PORT, LCD_D7_PIN, (val >> 3) & 0x01);
    LCD_PulseEnable();
}

void LCD_SendCommand(uint8_t cmd) {
    HAL_GPIO_WritePin(LCD_RS_GPIO_PORT, LCD_RS_PIN, GPIO_PIN_RESET);
    LCD_Write4Bit(cmd >> 4);
    LCD_Write4Bit(cmd & 0x0F);
}

void LCD_SendData(uint8_t data) {
    HAL_GPIO_WritePin(LCD_RS_GPIO_PORT, LCD_RS_PIN, GPIO_PIN_SET);
    LCD_Write4Bit(data >> 4);
    LCD_Write4Bit(data & 0x0F);
}

void LCD_Init(void) {
    HAL_Delay(50);
    HAL_GPIO_WritePin(LCD_RS_GPIO_PORT, LCD_RS_PIN, GPIO_PIN_RESET);
    LCD_Write4Bit(0x03);
    HAL_Delay(5);
    LCD_Write4Bit(0x03);
    HAL_Delay(1);
    LCD_Write4Bit(0x03);
    LCD_Write4Bit(0x02);

    LCD_SendCommand(0x28);
    LCD_SendCommand(0x0C);
    LCD_SendCommand(0x06);
    LCD_SendCommand(0x01);
    HAL_Delay(2);
}

void LCD_DisplayString(uint8_t row, uint8_t col, char *str) {
    uint8_t address = (row == 0) ? (0x80 + col) : (0xC0 + col);
    LCD_SendCommand(address);
    while (*str) {
        LCD_SendData((uint8_t)*str++);
    }
}

void MPU6050_Read_DMP(int32_t *p, int32_t *y, int32_t *r) {
    short gyro[3], accel[3], sensors;
    long quat[4];
    unsigned char more;
    float q0, q1, q2, q3;
    float pitch, yaw, roll;

    // Rút gói dữ liệu từ FIFO buffer
    if (dmp_read_fifo(gyro, accel, quat, NULL, &sensors, &more) == 0) {
        if (sensors & INV_WXYZ_QUAT) {
            // DMP xuất Quaternion dưới dạng số nguyên lớn, phải chia cho 2^30
            q0 = quat[0] / 1073741824.0f;
            q1 = quat[1] / 1073741824.0f;
            q2 = quat[2] / 1073741824.0f;
            q3 = quat[3] / 1073741824.0f;

            // Dùng Toán học giải mã Quaternion sang Euler Angles (Radian)
            pitch = asin(2.0f * (q0*q2 - q3*q1));
            yaw   = atan2(2.0f * (q0*q3 + q1*q2), q0*q0 + q1*q1 - q2*q2 - q3*q3);
            roll  = atan2(2.0f * (q0*q1 + q2*q3), q0*q0 - q1*q1 - q2*q2 + q3*q3);

            // Đổi Radian sang Độ, lượng tử hóa (nhân 100) rồi ép kiểu như thiết kế
            // Hệ số 5729.57795f chính là (180 / PI) * 100
            *p = (int32_t)(pitch * 5729.57795f);
            *y = (int32_t)(yaw * 5729.57795f);
            *r = (int32_t)(roll * 5729.57795f);
        }
    }
}
