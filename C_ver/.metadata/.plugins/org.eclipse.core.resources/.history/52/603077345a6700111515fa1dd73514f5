/* USER CODE BEGIN 4 */
void NRF24L01_Transmit(uint8_t *data, uint32_t size) {
    uint32_t bytes_sent = 0;
    uint8_t tx_payload[32];

    while (bytes_sent < size) {
        uint8_t chunk_size = (size - bytes_sent >= 32) ? 32 : (size - bytes_sent);

        memset(tx_payload, 0, 32);
        memcpy(tx_payload, &data[bytes_sent], chunk_size);

        // Kéo CSN xuống LOW để bắt đầu giao tiếp SPI
        HAL_GPIO_WritePin(NRF_CSN_GPIO_PORT, NRF_CSN_PIN, GPIO_PIN_RESET);

        // Gửi mã lệnh W_TX_PAYLOAD (0xA0)
        uint8_t cmd = 0xA0;
        HAL_SPI_Transmit(&hspi1, &cmd, 1, HAL_MAX_DELAY);

        // Gửi data
        HAL_SPI_Transmit(&hspi1, tx_payload, 32, HAL_MAX_DELAY);

        // Kéo CSN lên HIGH kết thúc SPI
        HAL_GPIO_WritePin(NRF_CSN_GPIO_PORT, NRF_CSN_PIN, GPIO_PIN_SET);

        // Tạo xung CE > 10us để phát
        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_SET);
        HAL_Delay(1);
        HAL_GPIO_WritePin(NRF_CE_GPIO_PORT, NRF_CE_PIN, GPIO_PIN_RESET);

        HAL_Delay(2);

        bytes_sent += chunk_size;
    }
}

